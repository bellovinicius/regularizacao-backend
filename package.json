{
  "name": "regularizacao-ambiental-backend",
  "version": "0.1.0",
  "description": "Platform SaaS para regularização ambiental rural no Brasil",
  "main": "dist/index.js",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "npx prisma migrate dev",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "4.18.2",
    "prisma": "5.7.1",
    "@prisma/client": "5.7.1",
    "jsonwebtoken": "9.0.2",
    "bcryptjs": "2.4.3",
    "dotenv": "16.3.1",
    "zod": "3.22.4",
    "uuid": "9.0.1",
    "axios": "1.6.2",
    "winston": "3.11.0",
    "cors": "2.8.5",
    "helmet": "7.1.0",
    "pg": "8.11.3"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.10.6",
    "@types/jsonwebtoken": "9.0.7",
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/uuid": "9.0.7",
    "typescript": "5.3.3",
    "ts-node": "10.9.2",
    "@typescript-eslint/eslint-plugin": "6.17.0",
    "@typescript-eslint/parser": "6.17.0",
    "eslint": "8.56.0"
  }
}
