generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id            String    @id @default(uuid()) @db.Uuid
  razaoSocial   String
  cnpj          String    @unique
  plano         String    @default("basic")
  ativo         Boolean   @default(true)
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  usuarios      Usuario[]
  clientes      Cliente[]
  processos     Processo[]

  @@map("empresa")
}

model Usuario {
  id            String    @id @default(uuid()) @db.Uuid
  empresaId     String    @db.Uuid
  empresa       Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nome          String
  email         String
  senhaHash     String
  role          String    @default("administrativo")
  ativo         Boolean   @default(true)
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  processos     Processo[]
  auditorias    Auditoria[]

  @@unique([empresaId, email])
  @@map("usuario")
}

model Cliente {
  id            String    @id @default(uuid()) @db.Uuid
  empresaId     String    @db.Uuid
  empresa       Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nome          String
  cpfCnpj       String
  telefone      String?
  email         String?
  scoreBant     Int       @default(0)
  status        String    @default("lead")
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  processos     Processo[]

  @@unique([empresaId, cpfCnpj])
  @@map("cliente")
}

model Processo {
  id            String    @id @default(uuid()) @db.Uuid
  empresaId     String    @db.Uuid
  empresa       Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  clienteId     String    @db.Uuid
  cliente       Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  numeroProcesso String
  etapaAtual    Int       @default(1)
  status        String    @default("ativo")
  valorTotal    Decimal   @db.Decimal(12, 2)
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  imovel        Imovel?
  etapas        EtapaProcesso[]
  documentos    Documento[]
  pagamentos    Pagamento[]
  auditorias    Auditoria[]

  @@unique([empresaId, numeroProcesso])
  @@map("processo")
}

model Imovel {
  id            String    @id @default(uuid()) @db.Uuid
  processoId    String    @unique @db.Uuid
  processo      Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  matricula     String
  areaHectares  Decimal   @db.Decimal(10, 2)
  municipio     String
  estado        String    @db.VarChar(2)
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  @@map("imovel")
}

model EtapaProcesso {
  id            String    @id @default(uuid()) @db.Uuid
  processoId    String    @db.Uuid
  processo      Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  numeroEtapa   Int
  status        String    @default("nao_iniciado")
  dataInicio    DateTime?
  dataConclusao DateTime?
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  @@unique([processoId, numeroEtapa])
  @@map("etapa_processo")
}

model Documento {
  id              String    @id @default(uuid()) @db.Uuid
  processoId      String    @db.Uuid
  processo        Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  tipo            String
  nomeArquivo     String
  s3Url           String
  statusValidacao String    @default("pendente")
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  @@map("documento")
}

model Pagamento {
  id              String    @id @default(uuid()) @db.Uuid
  processoId      String    @db.Uuid
  processo        Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  numeroParcela   Int
  valor           Decimal   @db.Decimal(12, 2)
  dataVencimento  DateTime  @db.Date()
  statusPagamento String    @default("pendente")
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  @@map("pagamento")
}

model Auditoria {
  id            String    @id @default(uuid()) @db.Uuid
  processoId    String    @db.Uuid
  processo      Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  usuarioId     String?   @db.Uuid
  usuario       Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  acao          String
  timestamp     DateTime  @default(now())

  @@map("auditoria")
}
