{
  "compilerOptions": {
    "target": "ES2020",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "types": ["node"],

    "lib": ["ES2020"],

    "outDir": "./dist",

    "rootDir": "./src",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "resolveJsonModule": true
  },

  "include": ["src"]
}
