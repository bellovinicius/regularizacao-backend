{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "removeComments": true
  },
  "include": [
    "src/app.ts",
    "src/server.ts",
    "src/config/**/*.ts",
    "src/controllers/**/*.ts",
    "src/middleware/**/*.ts",
    "src/repositories/**/*.ts",
    "src/routes/**/*.ts",
    "src/services/auth.service.ts",
    "src/services/processo.service.ts",
    "src/types/**/*.ts",
    "src/utils/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.tsx",
    "src/**/*.jsx",
    "src/**/*.css",
    "src/pages/**",
    "src/components/**",
    "src/hooks/**",
    "src/main.tsx",
    "src/App.tsx",
    "src/services/api.ts"
  ]
}
